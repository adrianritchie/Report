@page "/"
@rendermode InteractiveServer

@using ReportGenerator.Configuration
@using ReportGenerator.Web.Models
@using ReportGenerator.Web.Services

@inject WorkspaceStore WorkspaceStore
@inject OllamaOptions OllamaOptions
@inject ReportOptions ReportOptions
@inject NavigationManager Navigation

<div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 mb-6">
    <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-3">Workspace Home</h2>
    <p class="text-sm text-slate-600">Create and reopen workspaces by workflow type.</p>
</div>

@if (_errorMessage is not null)
{
    <div class="flex items-start gap-3 border-l-4 border-red-500 bg-red-50 text-red-800 px-4 py-3 rounded-r-xl mb-4 text-sm">
        <span>@_errorMessage</span>
    </div>
}

<div class="grid grid-cols-1 gap-6">
    <section class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
        <div class="flex items-center justify-between gap-3 mb-4">
            <div>
                <h3 class="text-sm font-semibold text-slate-800">Feedback Report Workspaces</h3>
                <p class="text-xs text-slate-500">Use these for student response spreadsheet workflows.</p>
            </div>
            <button class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-4 py-2 rounded-lg text-sm"
                    @onclick="CreateFeedbackWorkspaceAsync"
                    disabled="@_isBusy">
                Create Feedback Workspace
            </button>
        </div>

        @if (_feedbackWorkspaces.Count == 0)
        {
            <div class="rounded-lg border border-dashed border-slate-300 bg-slate-50 px-4 py-5">
                <p class="text-sm font-medium text-slate-700">No feedback workspaces yet.</p>
                <p class="text-xs text-slate-500 mt-1">Create one to prepare prompts, preprocess student responses, and generate reports incrementally.</p>
            </div>
        }
        else
        {
            <div class="space-y-2">
                @foreach (var ws in _feedbackWorkspaces)
                {
                    <div class="flex flex-wrap items-center gap-3 border border-slate-200 rounded-lg px-3 py-2">
                        <span class="text-sm font-semibold text-slate-700">@ws.Name</span>
                        <span class="text-xs text-slate-500">v@ws.CurrentVersion</span>
                        <span class="text-xs text-slate-400">Updated @ws.UpdatedUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</span>
                        <button class="ml-auto text-xs text-slate-700 hover:text-slate-900 font-medium" @onclick="() => CloneWorkspaceAsync(ws.Id)">Clone</button>
                        <button class="text-xs text-rose-700 hover:text-rose-900 font-medium" @onclick="() => DeleteWorkspaceAsync(ws.Id)">Delete</button>
                        <button class="text-sm text-indigo-700 hover:text-indigo-900 font-medium" @onclick="() => OpenFeedbackWorkspace(ws.Id)">Open</button>
                    </div>
                }
            </div>
        }
    </section>

    <section class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
        <div class="flex items-center justify-between gap-3 mb-4">
            <div>
                <h3 class="text-sm font-semibold text-slate-800">Results Reports Workspaces</h3>
                <p class="text-xs text-slate-500">Use these for marks/results spreadsheet workflows.</p>
            </div>
            <button class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-4 py-2 rounded-lg text-sm"
                    @onclick="CreateResultsWorkspaceAsync"
                    disabled="@_isBusy">
                Create Results Workspace
            </button>
        </div>

        @if (_resultsWorkspaces.Count == 0)
        {
            <div class="rounded-lg border border-dashed border-slate-300 bg-slate-50 px-4 py-5">
                <p class="text-sm font-medium text-slate-700">No results-analysis workspaces yet.</p>
                <p class="text-xs text-slate-500 mt-1">Create one to process exam context and marks data, then generate results-analysis reports.</p>
            </div>
        }
        else
        {
            <div class="space-y-2">
                @foreach (var ws in _resultsWorkspaces)
                {
                    <div class="flex flex-wrap items-center gap-3 border border-slate-200 rounded-lg px-3 py-2">
                        <span class="text-sm font-semibold text-slate-700">@ws.Name</span>
                        <span class="text-xs text-slate-500">v@ws.CurrentVersion</span>
                        <span class="text-xs text-slate-400">Updated @ws.UpdatedUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</span>
                        <button class="ml-auto text-xs text-slate-700 hover:text-slate-900 font-medium" @onclick="() => CloneWorkspaceAsync(ws.Id)">Clone</button>
                        <button class="text-xs text-rose-700 hover:text-rose-900 font-medium" @onclick="() => DeleteWorkspaceAsync(ws.Id)">Delete</button>
                        <button class="text-sm text-indigo-700 hover:text-indigo-900 font-medium" @onclick="() => OpenResultsWorkspace(ws.Id)">Open</button>
                    </div>
                }
            </div>
        }
    </section>
</div>

@code {
    private readonly List<WorkspaceSummary> _feedbackWorkspaces = [];
    private readonly List<WorkspaceSummary> _resultsWorkspaces = [];
    private bool _isBusy;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _feedbackWorkspaces.Clear();
        _resultsWorkspaces.Clear();

        _feedbackWorkspaces.AddRange(await WorkspaceStore.ListAsync(WorkspaceKinds.Feedback));
        _resultsWorkspaces.AddRange(await WorkspaceStore.ListAsync(WorkspaceKinds.Results));
    }

    private async Task CreateFeedbackWorkspaceAsync()
    {
        await CreateAndOpenAsync(WorkspaceKinds.Feedback, "/feedback");
    }

    private async Task CreateResultsWorkspaceAsync()
    {
        await CreateAndOpenAsync(WorkspaceKinds.Results, "/results");
    }

    private async Task CreateAndOpenAsync(string kind, string route)
    {
        _isBusy = true;
        _errorMessage = null;
        try
        {
            var created = await WorkspaceStore.CreateAsync(
                $"Workspace {DateTimeOffset.Now:yyyy-MM-dd HHmm}",
                kind,
                OllamaOptions.Model,
                ReportOptions.DefaultPrompt,
                ReportOptions.DefaultTask);

            Navigation.NavigateTo($"{route}?workspaceId={Uri.EscapeDataString(created.Id)}", forceLoad: true);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task CloneWorkspaceAsync(string workspaceId)
    {
        _isBusy = true;
        _errorMessage = null;
        try
        {
            var source = await WorkspaceStore.GetAsync(workspaceId);
            var clone = await WorkspaceStore.CloneAsync(workspaceId, $"{source.Name} Copy");

            await RefreshAsync();
            if (string.Equals(clone.Kind, WorkspaceKinds.Feedback, StringComparison.OrdinalIgnoreCase))
            {
                Navigation.NavigateTo($"/feedback?workspaceId={Uri.EscapeDataString(clone.Id)}", forceLoad: true);
            }
            else
            {
                Navigation.NavigateTo($"/results?workspaceId={Uri.EscapeDataString(clone.Id)}", forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task DeleteWorkspaceAsync(string workspaceId)
    {
        _isBusy = true;
        _errorMessage = null;
        try
        {
            await WorkspaceStore.DeleteAsync(workspaceId);
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void OpenWorkspace(string route, string workspaceId)
    {
        Navigation.NavigateTo($"{route}?workspaceId={Uri.EscapeDataString(workspaceId)}", forceLoad: true);
    }

    private void OpenFeedbackWorkspace(string workspaceId) => OpenWorkspace("/feedback", workspaceId);

    private void OpenResultsWorkspace(string workspaceId) => OpenWorkspace("/results", workspaceId);
}
