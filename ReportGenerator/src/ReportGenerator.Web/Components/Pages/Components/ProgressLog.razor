@using ReportGenerator.Web.Models

@if (Steps is { Count: > 0 })
{
    @* Overall progress bar — shown once student steps exist *@
    @if (TotalStudents > 0)
    {
        var pct = TotalStudents == 0 ? 0 : (int)Math.Round(DoneStudents * 100.0 / TotalStudents);
        <div class="mb-4">
            <div class="flex justify-between items-center mb-1">
                <span class="text-xs font-medium text-slate-500">Overall progress</span>
                <span class="text-xs font-semibold text-indigo-600">@DoneStudents / @TotalStudents</span>
            </div>
            <div class="w-full h-2 bg-slate-200 rounded-full overflow-hidden">
                <div class="h-2 bg-indigo-500 rounded-full transition-all duration-500"
                     style="width: @(pct)%"></div>
            </div>
        </div>
    }

    @* Step timeline *@
    <ol class="space-y-0">
        @for (var i = 0; i < Steps.Count; i++)
        {
            var step = Steps[i];
            var isLast = i == Steps.Count - 1;

            <li class="flex gap-3 min-h-[2.5rem]">

                @* Left column: connector line + icon *@
                <div class="flex flex-col items-center">
                    <div class="@IconBg(step.Status) w-7 h-7 rounded-full flex items-center justify-center flex-shrink-0 z-10 @(step.Status == StepStatus.InProgress ? "ring-4 ring-indigo-100" : "")">
                        @if (step.Status == StepStatus.InProgress)
                        {
                            @* Animated spinner *@
                            <svg class="animate-spin w-4 h-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
                            </svg>
                        }
                        else if (step.Status == StepStatus.Pending)
                        {
                            <div class="w-2.5 h-2.5 rounded-full bg-slate-300"></div>
                        }
                        else if (step.Status == StepStatus.Done)
                        {
                            @* Checkmark *@
                            <svg class="w-3.5 h-3.5 text-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 00-1.414 0L8 12.586 4.707 9.293a1 1 0 00-1.414 1.414l4 4a1 1 0 001.414 0l8-8a1 1 0 000-1.414z" clip-rule="evenodd" />
                            </svg>
                        }
                        else if (step.Status == StepStatus.Skipped)
                        {
                            @* Dash *@
                            <svg class="w-3.5 h-3.5 text-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M4 10a1 1 0 011-1h10a1 1 0 110 2H5a1 1 0 01-1-1z" clip-rule="evenodd" />
                            </svg>
                        }
                        else if (step.Status == StepStatus.Failed)
                        {
                            @* X *@
                            <svg class="w-3.5 h-3.5 text-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                            </svg>
                        }
                    </div>
                    @if (!isLast)
                    {
                        <div class="w-px flex-1 @(step.Status == StepStatus.Pending ? "bg-slate-200" : "bg-slate-300") mt-0.5 mb-0.5"></div>
                    }
                </div>

                @* Right column: label + detail *@
                <div class="pb-4 pt-0.5 flex-1 min-w-0">
                    <p class="text-sm font-medium @LabelColor(step.Status)">@step.Label</p>
                    @if (!string.IsNullOrWhiteSpace(step.Detail))
                    {
                        <p class="text-xs mt-0.5 @DetailColor(step.Status)">@step.Detail</p>
                    }
                </div>

            </li>
        }
    </ol>
}

@code {
    [Parameter] public IReadOnlyList<ProgressStep>? Steps { get; set; }
    [Parameter] public int TotalStudents { get; set; }
    [Parameter] public int DoneStudents { get; set; }

    private static string IconBg(StepStatus s) => s switch
    {
        StepStatus.Pending    => "bg-slate-200",
        StepStatus.InProgress => "bg-indigo-500",
        StepStatus.Done       => "bg-emerald-500",
        StepStatus.Skipped    => "bg-amber-400",
        StepStatus.Failed     => "bg-red-500",
        _                     => "bg-slate-200"
    };

    private static string LabelColor(StepStatus s) => s switch
    {
        StepStatus.Pending    => "text-slate-400",
        StepStatus.InProgress => "text-indigo-700",
        StepStatus.Done       => "text-emerald-700",
        StepStatus.Skipped    => "text-amber-700",
        StepStatus.Failed     => "text-red-700",
        _                     => "text-slate-500"
    };

    private static string DetailColor(StepStatus s) => s switch
    {
        StepStatus.Failed  => "text-red-500",
        StepStatus.Skipped => "text-amber-500",
        _                  => "text-slate-400"
    };
}
