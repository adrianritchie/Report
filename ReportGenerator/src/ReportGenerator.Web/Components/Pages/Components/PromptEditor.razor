<label for="prompt-editor" class="block text-sm font-semibold text-slate-700 mb-1">
    Teacher Instructions / Prompt
</label>
<textarea id="prompt-editor" rows="5"
          class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm resize-vertical focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 font-mono"
          @bind="Prompt" @bind:event="oninput"
          @bind:after="OnPromptChanged">
</textarea>

@code {
    [Parameter] public string Prompt { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> PromptChanged { get; set; }

    private async Task OnPromptChanged()
        => await PromptChanged.InvokeAsync(Prompt);
}
