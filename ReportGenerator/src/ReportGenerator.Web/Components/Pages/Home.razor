@page "/feedback"
@rendermode InteractiveServer

@using ReportGenerator.Configuration
@using ReportGenerator.Web.Models
@using ReportGenerator.Web.Services

@inject WorkspaceStore WorkspaceStore
@inject WorkspacePipelineService WorkspacePipeline
@inject DownloadTokenStore DownloadTokenStore
@inject OllamaOptions OllamaOptions
@inject ReportOptions ReportOptions

<div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 mb-6">
    <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-5">Workspace</h2>

    <div class="flex flex-col gap-4">
        <div class="flex flex-wrap items-end gap-3">
            <div class="min-w-64 flex-1">
                <label class="block text-sm font-medium text-slate-700 mb-1.5">Current Workspace</label>
                <select class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm"
                        value="@_selectedWorkspaceId"
                        @onchange="OnWorkspaceChanged">
                    @foreach (var ws in _workspaces)
                    {
                        <option value="@ws.Id">@ws.Name (v@ws.CurrentVersion)</option>
                    }
                </select>
            </div>
            <button class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-4 py-2.5 rounded-lg text-sm"
                    @onclick="CreateWorkspaceAsync">
                Create Workspace
            </button>
            <button class="inline-flex items-center gap-2 border border-slate-300 text-slate-700 hover:bg-slate-100 font-medium px-4 py-2.5 rounded-lg text-sm"
                    @onclick="RenameWorkspaceAsync"
                    disabled="@(_workspace is null)">
                Rename
            </button>
            <button class="inline-flex items-center gap-2 border border-rose-300 text-rose-700 hover:bg-rose-50 font-medium px-4 py-2.5 rounded-lg text-sm"
                    @onclick="DeleteWorkspaceAsync"
                    disabled="@(_workspace is null || _workspaces.Count <= 1)">
                Delete
            </button>
        </div>

        <div class="flex flex-wrap items-end gap-3">
            <div class="min-w-64 flex-1">
                <label class="block text-sm font-medium text-slate-700 mb-1.5">Workspace Name</label>
                <input class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm"
                       @bind="_workspaceNameDraft"
                       @bind:event="oninput" />
            </div>
            <span class="text-xs text-slate-500">Version @(_workspace?.CurrentVersion ?? 0)</span>
        </div>
    </div>
</div>

@if (_workspace is not null)
{
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 mb-6">
        <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-5">Configuration</h2>

        <div class="grid grid-cols-1 gap-5">
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1.5">Model</label>
                <ModelSelector @bind-SelectedModel="_selectedModel" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1.5">Teacher Instructions</label>
                <PromptEditor @bind-Prompt="_prompt" />
            </div>

            <div class="border border-slate-200 rounded-lg overflow-hidden">
                <button type="button"
                        class="w-full flex items-center justify-between px-4 py-3 bg-slate-50 hover:bg-slate-100 transition-colors text-left"
                        @onclick="() => _taskExpanded = !_taskExpanded">
                    <div>
                        <span class="text-sm font-medium text-slate-700">Task Instructions</span>
                        <span class="ml-2 text-xs text-slate-400">(click to @(_taskExpanded ? "collapse" : "expand"))</span>
                    </div>
                </button>
                @if (_taskExpanded)
                {
                    <div class="px-4 py-3 border-t border-slate-200">
                        <textarea rows="8"
                                  class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm resize-y"
                                  @bind="_task"
                                  @bind:event="oninput">
                        </textarea>
                    </div>
                }
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1.5">Example Reports</label>
                <ExampleReportsPanel Examples="_examples" UseBrowserStorage="false" ExamplesChanged="OnExamplesChanged" />
            </div>
        </div>

        <div class="mt-4">
            <button class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-5 py-2.5 rounded-lg text-sm"
                    @onclick="SaveConfigurationAsync">
                Save Prompt & Config
            </button>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 mb-6">
        <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-5">Stage Processing</h2>

        <div class="grid grid-cols-1 gap-4">
            <div class="rounded-lg border border-slate-200 p-4">
                <div class="flex items-center justify-between gap-3 mb-3">
                    <div>
                        <p class="text-sm font-semibold text-slate-700">Process Exam Paper</p>
                        <p class="text-xs text-slate-500">Extract text + generate editable summary. Saved automatically.</p>
                    </div>
                    <span class="text-xs text-slate-500">@RenderProcessed(_workspace.Exam.ProcessedUtc)</span>
                </div>
                <InputFile OnChange="OnExamUpload" accept=".pdf,.txt,.md,.text,.doc,.rtf,.docx"
                           class="block w-full text-sm text-slate-600 file:mr-3 file:py-1.5 file:px-3 file:rounded file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700" />
                <div class="mt-3 flex flex-wrap gap-3 items-center">
                    <button class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-4 py-2 rounded-lg text-sm"
                            @onclick="ProcessExamAsync"
                            disabled="@(_examUploadData is null || _isBusy)">
                        Process Exam
                    </button>
                    <span class="text-xs text-slate-500">@(_workspace.Exam.SourceFileName ?? "No file processed yet")</span>
                </div>

                @if (!string.IsNullOrWhiteSpace(_examSummaryEditable))
                {
                    <div class="mt-3">
                        <label class="block text-xs font-medium text-slate-600 mb-1">Editable summary (persisted)</label>
                        <textarea class="w-full rounded-md border border-slate-300 bg-slate-50 px-3 py-2 text-xs font-mono"
                                  rows="10"
                                  @bind="_examSummaryEditable"
                                  @bind:event="oninput"></textarea>
                        <button class="mt-2 inline-flex items-center gap-2 border border-slate-300 text-slate-700 hover:bg-slate-100 font-medium px-4 py-2 rounded-lg text-xs"
                                @onclick="SaveExamSummaryAsync"
                                disabled="@_isBusy">
                            Save Edited Summary
                        </button>
                    </div>
                }
            </div>

            <div class="rounded-lg border border-slate-200 p-4">
                <div class="flex items-center justify-between gap-3 mb-3">
                    <div>
                        <p class="text-sm font-semibold text-slate-700">Preprocess Spreadsheet</p>
                        <p class="text-xs text-slate-500">Parse and persist student rows for report generation.</p>
                    </div>
                    <span class="text-xs text-slate-500">@RenderProcessed(_workspace.Sheet.ProcessedUtc)</span>
                </div>
                <InputFile OnChange="OnSheetUpload" accept=".xlsx"
                           class="block w-full text-sm text-slate-600 file:mr-3 file:py-1.5 file:px-3 file:rounded file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700" />
                <div class="mt-3 flex flex-wrap gap-3 items-center">
                    <button class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-4 py-2 rounded-lg text-sm"
                            @onclick="PreprocessSheetAsync"
                            disabled="@(_sheetUploadData is null || _isBusy)">
                        Preprocess Spreadsheet
                    </button>
                    <span class="text-xs text-slate-500">@(_workspace.Sheet.Students.Count) student(s) loaded</span>
                </div>

                @if (_sheetPreviewStudents.Count > 0)
                {
                    var headings = GetSheetHeadings();
                    <div class="mt-4 rounded-lg border border-slate-200 overflow-x-auto">
                        <table class="w-full text-xs text-left border-collapse">
                            <thead class="bg-slate-100 text-slate-600 uppercase tracking-wider">
                                <tr>
                                    <th class="px-2 py-2 font-semibold min-w-40">Name</th>
                                    @foreach (var heading in headings)
                                    {
                                        <th class="px-2 py-2 font-semibold min-w-40">@heading</th>
                                    }
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100">
                                @for (var studentIndex = 0; studentIndex < _sheetPreviewStudents.Count; studentIndex++)
                                {
                                    var row = _sheetPreviewStudents[studentIndex];
                                    <tr>
                                        <td class="px-2 py-2 align-top">
                                            <input class="w-full rounded border border-slate-300 bg-white px-2 py-1"
                                                   value="@row.Name"
                                                   @oninput="e => OnSheetStudentNameChanged(studentIndex, e.Value?.ToString() ?? string.Empty)" />
                                        </td>
                                        @foreach (var heading in headings)
                                        {
                                            <td class="px-2 py-2 align-top">
                                                <input class="w-full rounded border border-slate-300 bg-white px-2 py-1"
                                                       value="@GetSheetFieldValue(row, heading)"
                                                       @oninput="e => OnSheetStudentFieldChanged(studentIndex, heading, e.Value?.ToString() ?? string.Empty)" />
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <button class="mt-3 inline-flex items-center gap-2 border border-slate-300 text-slate-700 hover:bg-slate-100 font-medium px-4 py-2 rounded-lg text-xs"
                            @onclick="SaveSheetSnapshotAsync"
                            disabled="@_isBusy">
                        Save Edited Spreadsheet Data
                    </button>
                }
            </div>

            <div class="rounded-lg border border-slate-200 p-4">
                <div class="flex items-center justify-between gap-3 mb-3">
                    <div>
                        <p class="text-sm font-semibold text-slate-700">Generate Reports</p>
                        <p class="text-xs text-slate-500">Uses persisted prompt, exam summary, and preprocessed sheet.</p>
                    </div>
                </div>
                <button class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-4 py-2 rounded-lg text-sm"
                        @onclick="GenerateReportsAsync"
                        disabled="@(_isBusy || string.IsNullOrWhiteSpace(_workspace.Exam.SummaryFinal) || _workspace.Sheet.Students.Count == 0)">
                    Generate Reports
                </button>
                @if (_workspace.Reports.Runs.Count > 0)
                {
                    <span class="text-xs text-slate-500 ml-3">Latest run: @_workspace.Reports.Runs[0].RunId</span>
                }
            </div>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 mb-6">
        <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-5">Version History</h2>
        <div class="space-y-2">
            @foreach (var version in _workspace.Versions)
            {
                <div class="flex flex-wrap items-center gap-3 border border-slate-200 rounded-lg px-3 py-2">
                    <span class="text-xs font-semibold text-slate-700">v@version.Number</span>
                    <span class="text-xs text-slate-500">@version.Reason</span>
                    <span class="text-xs text-slate-400">@version.CreatedUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</span>
                    <button class="ml-auto text-xs text-indigo-700 hover:text-indigo-900" @onclick="() => PreviewDiffAsync(version.Number)">Preview Diff</button>
                    <button class="text-xs text-amber-700 hover:text-amber-900" @onclick="() => RestoreVersionAsync(version.Number)">Restore</button>
                </div>
            }
        </div>

        @if (_diffPreview is not null)
        {
            <div class="mt-4 rounded-lg border border-indigo-200 bg-indigo-50 p-4">
                <p class="text-sm font-semibold text-indigo-800 mb-2">Diff preview vs v@_diffPreview.VersionNumber (@_diffPreview.Reason)</p>
                @foreach (var diffSection in _diffPreview.Sections)
                {
                    <div class="mb-2">
                        <p class="text-xs font-semibold text-indigo-700">@diffSection.Title</p>
                        @foreach (var line in diffSection.Lines)
                        {
                            <p class="text-xs text-indigo-800">- @line</p>
                        }
                    </div>
                }
            </div>
        }
    </div>
}

@if (_errorMessage is not null)
{
    <div class="flex items-start gap-3 border-l-4 border-red-500 bg-red-50 text-red-800 px-4 py-3 rounded-r-xl mb-4 text-sm">
        <span>@_errorMessage</span>
    </div>
}

@if (_progressSteps.Count > 0)
{
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 mb-6">
        <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-5">Generation Progress</h2>
        <ProgressLog Steps="_progressSteps" TotalStudents="@_totalStudents" DoneStudents="@_doneStudents" />
    </div>
}

@if (_reportRows.Count > 0)
{
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 mb-6 overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100">
            <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-widest">Results</h2>
        </div>
        <ResultsTable Rows="_reportRows" />
    </div>
}

<DownloadButton Token="@_downloadToken" />

@code {
    private const string WorkspaceKind = WorkspaceKinds.Feedback;

    [SupplyParameterFromQuery(Name = "workspaceId")]
    public string? WorkspaceId { get; set; }

    private List<WorkspaceSummary> _workspaces = [];
    private WorkspaceState? _workspace;
    private string? _selectedWorkspaceId;
    private string _workspaceNameDraft = string.Empty;

    private string _selectedModel = string.Empty;
    private string _prompt = string.Empty;
    private string _task = string.Empty;
    private bool _taskExpanded;
    private IReadOnlyList<ExampleReport> _examples = [];

    private string? _examUploadFileName;
    private byte[]? _examUploadData;
    private string? _sheetUploadFileName;
    private byte[]? _sheetUploadData;
    private string _examSummaryEditable = string.Empty;
    private List<WorkspaceStudentSnapshot> _sheetPreviewStudents = [];

    private bool _isBusy;
    private string? _errorMessage;
    private string? _downloadToken;
    private WorkspaceVersionDiff? _diffPreview;

    private readonly List<ProgressStep> _progressSteps = [];
    private readonly List<ReportRow> _reportRows = [];
    private int _totalStudents;
    private int _doneStudents;

    protected override async Task OnInitializedAsync()
    {
        await LoadWorkspacesAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_workspace is not null && string.Equals(_workspace.Id, WorkspaceId, StringComparison.Ordinal))
            return;

        if (_workspaces.Count == 0)
            return;

        var requested = WorkspaceId;
        if (!string.IsNullOrWhiteSpace(requested)
            && _workspaces.Any(w => string.Equals(w.Id, requested, StringComparison.Ordinal)))
        {
            _selectedWorkspaceId = requested;
            await LoadWorkspaceAsync(requested);
        }
    }

    private async Task LoadWorkspacesAsync()
    {
        _workspaces = (await WorkspaceStore.ListAsync(WorkspaceKind)).ToList();
        if (_workspaces.Count == 0)
        {
            var created = await WorkspaceStore.CreateAsync("Default Workspace", WorkspaceKind, OllamaOptions.Model, ReportOptions.DefaultPrompt, ReportOptions.DefaultTask);
            _workspaces = [new WorkspaceSummary
            {
                Id = created.Id,
                Name = created.Name,
                Kind = created.Kind,
                UpdatedUtc = created.UpdatedUtc,
                CurrentVersion = created.CurrentVersion,
            }];
        }

        if (!string.IsNullOrWhiteSpace(WorkspaceId)
            && _workspaces.Any(w => string.Equals(w.Id, WorkspaceId, StringComparison.Ordinal)))
        {
            _selectedWorkspaceId = WorkspaceId;
        }
        else
        {
            _selectedWorkspaceId ??= _workspaces[0].Id;
        }

        await LoadWorkspaceAsync(_selectedWorkspaceId);
    }

    private async Task LoadWorkspaceAsync(string? workspaceId)
    {
        if (string.IsNullOrWhiteSpace(workspaceId))
            return;

        _workspace = await WorkspaceStore.GetAsync(workspaceId);
        _workspaceNameDraft = _workspace.Name;
        _selectedWorkspaceId = _workspace.Id;
        _selectedModel = _workspace.SelectedModel;
        _prompt = string.IsNullOrWhiteSpace(_workspace.Prompt) ? ReportOptions.DefaultPrompt : _workspace.Prompt;
        _task = string.IsNullOrWhiteSpace(_workspace.Task) ? ReportOptions.DefaultTask : _workspace.Task;
        _examples = _workspace.Examples.AsReadOnly();
        _examSummaryEditable = _workspace.Exam.SummaryFinal ?? string.Empty;
        _sheetPreviewStudents = Clone(_workspace.Sheet.Students);
        _diffPreview = null;

        LoadLatestRunRows();
    }

    private void LoadLatestRunRows()
    {
        _reportRows.Clear();
        _downloadToken = null;
        if (_workspace is null)
            return;

        var run = _workspace.Reports.Runs.FirstOrDefault();
        if (run is null)
            return;

        foreach (var row in run.Rows)
            _reportRows.Add(new ReportRow(row.SequenceNumber, row.StudentName, row.ReportText, row.PromptText));

        if (!string.IsNullOrWhiteSpace(run.ReportFilePath) && File.Exists(run.ReportFilePath))
            _downloadToken = DownloadTokenStore.Register(run.ReportFilePath);
    }

    private async Task OnWorkspaceChanged(ChangeEventArgs args)
    {
        var id = args.Value?.ToString();
        if (string.IsNullOrWhiteSpace(id))
            return;

        await LoadWorkspaceAsync(id);
    }

    private async Task CreateWorkspaceAsync()
    {
        _errorMessage = null;
        try
        {
            var created = await WorkspaceStore.CreateAsync(
                $"Workspace {DateTimeOffset.Now:yyyy-MM-dd HHmm}",
                WorkspaceKind,
                _selectedModel,
                _prompt,
                _task);

            await LoadWorkspacesAsync();
            await LoadWorkspaceAsync(created.Id);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private async Task RenameWorkspaceAsync()
    {
        if (_workspace is null)
            return;

        _errorMessage = null;
        try
        {
            await WorkspaceStore.RenameAsync(_workspace.Id, _workspaceNameDraft);
            await LoadWorkspacesAsync();
            await LoadWorkspaceAsync(_workspace.Id);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private async Task DeleteWorkspaceAsync()
    {
        if (_workspace is null || _workspaces.Count <= 1)
            return;

        var id = _workspace.Id;
        await WorkspaceStore.DeleteAsync(id);
        _selectedWorkspaceId = _workspaces.FirstOrDefault(w => w.Id != id)?.Id;
        await LoadWorkspacesAsync();
    }

    private Task OnExamplesChanged(IReadOnlyList<ExampleReport> examples)
    {
        _examples = examples;
        return Task.CompletedTask;
    }

    private async Task SaveConfigurationAsync()
    {
        if (_workspace is null)
            return;

        await RunBusyAsync(async () =>
        {
            _workspace = await WorkspacePipeline.SaveConfigurationAsync(_workspace.Id, _selectedModel, _prompt, _task, _examples);
            await LoadWorkspacesAsync();
            await LoadWorkspaceAsync(_workspace.Id);
        });
    }

    private async Task OnExamUpload(InputFileChangeEventArgs args)
    {
        var file = args.File;
        _examUploadFileName = file.Name;
        using var ms = new MemoryStream();
        await using var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
        await stream.CopyToAsync(ms);
        _examUploadData = ms.ToArray();
    }

    private async Task OnSheetUpload(InputFileChangeEventArgs args)
    {
        var file = args.File;
        _sheetUploadFileName = file.Name;
        using var ms = new MemoryStream();
        await using var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
        await stream.CopyToAsync(ms);
        _sheetUploadData = ms.ToArray();
    }

    private async Task ProcessExamAsync()
    {
        if (_workspace is null || _examUploadData is null || string.IsNullOrWhiteSpace(_examUploadFileName))
            return;

        await RunBusyAsync(async () =>
        {
            _workspace = await WorkspacePipeline.ProcessExamAsync(
                _workspace.Id,
                _examUploadFileName,
                _examUploadData,
                _examSummaryEditable);

            await LoadWorkspacesAsync();
            await LoadWorkspaceAsync(_workspace.Id);
        });
    }

    private async Task SaveExamSummaryAsync()
    {
        if (_workspace is null)
            return;

        await RunBusyAsync(async () =>
        {
            _workspace = await WorkspacePipeline.SaveExamSummaryAsync(_workspace.Id, _examSummaryEditable);
            await LoadWorkspacesAsync();
            await LoadWorkspaceAsync(_workspace.Id);
        });
    }

    private async Task PreprocessSheetAsync()
    {
        if (_workspace is null || _sheetUploadData is null || string.IsNullOrWhiteSpace(_sheetUploadFileName))
            return;

        await RunBusyAsync(async () =>
        {
            _workspace = await WorkspacePipeline.PreprocessSheetAsync(_workspace.Id, _sheetUploadFileName, _sheetUploadData);
            await LoadWorkspacesAsync();
            await LoadWorkspaceAsync(_workspace.Id);
        });
    }

    private async Task SaveSheetSnapshotAsync()
    {
        if (_workspace is null || _sheetPreviewStudents.Count == 0)
            return;

        await RunBusyAsync(async () =>
        {
            _workspace = await WorkspacePipeline.SaveSheetSnapshotAsync(_workspace.Id, _sheetPreviewStudents);
            await LoadWorkspacesAsync();
            await LoadWorkspaceAsync(_workspace.Id);
        });
    }

    private List<string> GetSheetHeadings()
    {
        var headings = new List<string>();
        foreach (var student in _sheetPreviewStudents)
        {
            foreach (var field in student.Fields)
            {
                if (!headings.Contains(field.Heading, StringComparer.OrdinalIgnoreCase))
                    headings.Add(field.Heading);
            }
        }

        return headings;
    }

    private static string GetSheetFieldValue(WorkspaceStudentSnapshot student, string heading)
        => student.Fields.FirstOrDefault(f => string.Equals(f.Heading, heading, StringComparison.OrdinalIgnoreCase))?.Value ?? string.Empty;

    private void OnSheetStudentNameChanged(int studentIndex, string value)
    {
        if (studentIndex < 0 || studentIndex >= _sheetPreviewStudents.Count)
            return;

        _sheetPreviewStudents[studentIndex].Name = value;
    }

    private void OnSheetStudentFieldChanged(int studentIndex, string heading, string value)
    {
        if (studentIndex < 0 || studentIndex >= _sheetPreviewStudents.Count)
            return;

        var student = _sheetPreviewStudents[studentIndex];
        var field = student.Fields.FirstOrDefault(f => string.Equals(f.Heading, heading, StringComparison.OrdinalIgnoreCase));
        if (field is null)
        {
            student.Fields.Add(new WorkspaceFieldSnapshot { Heading = heading, Value = value });
            return;
        }

        field.Value = value;
    }

    private static List<WorkspaceStudentSnapshot> Clone(IReadOnlyList<WorkspaceStudentSnapshot> source)
        => source
            .Select(s => new WorkspaceStudentSnapshot
            {
                Name = s.Name,
                Fields = s.Fields.Select(f => new WorkspaceFieldSnapshot
                {
                    Heading = f.Heading,
                    Value = f.Value,
                }).ToList(),
            })
            .ToList();

    private async Task GenerateReportsAsync()
    {
        if (_workspace is null)
            return;

        _progressSteps.Clear();
        _doneStudents = 0;
        _totalStudents = _workspace.Sheet.Students.Count;

        await RunBusyAsync(async () =>
        {
            var result = await WorkspacePipeline.GenerateReportsAsync(
                _workspace.Id,
                step =>
                {
                    _progressSteps.Add(step);
                    if (step.Status == StepStatus.Done || step.Status == StepStatus.Skipped)
                        _doneStudents++;
                    InvokeAsync(StateHasChanged);
                });

            _workspace = result.Workspace;
            await LoadWorkspacesAsync();
            await LoadWorkspaceAsync(_workspace.Id);
        });
    }

    private async Task PreviewDiffAsync(int versionNumber)
    {
        if (_workspace is null)
            return;

        _diffPreview = await WorkspaceStore.BuildDiffPreviewAsync(_workspace.Id, versionNumber);
    }

    private async Task RestoreVersionAsync(int versionNumber)
    {
        if (_workspace is null)
            return;

        await RunBusyAsync(async () =>
        {
            _workspace = await WorkspaceStore.RestoreVersionAsync(_workspace.Id, versionNumber);
            await LoadWorkspacesAsync();
            await LoadWorkspaceAsync(_workspace.Id);
        });
    }

    private async Task RunBusyAsync(Func<Task> action)
    {
        _isBusy = true;
        _errorMessage = null;
        try
        {
            await action();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private static string RenderProcessed(DateTimeOffset? value)
        => value is null ? "Not processed" : $"Processed {value.Value.LocalDateTime:yyyy-MM-dd HH:mm}";
}
